# Server
PORT=5000
NODE_ENV=development

# CORS – comma-separated origin(s) allowed to call this API (Next.js frontend).
# Include both local dev and the deployed frontend URL, e.g.:
# CLIENT_ORIGIN=http://localhost:3000,https://ishbor-frontend.vercel.app
CLIENT_ORIGIN=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/ishbor_portal

# JWT (used to authenticate the test-taker on both REST and Socket.io)
JWT_SECRET=replace_this_with_a_long_random_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Assessment engine tuning
TEST_DURATION_MINUTES=30
HEARTBEAT_TIMEOUT_MS=15000
MAX_TAB_SWITCHES=3
MAX_VIOLATIONS=5
