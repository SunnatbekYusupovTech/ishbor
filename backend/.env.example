# Server
PORT=5000
NODE_ENV=development

# CORS – comma-separated origin(s) allowed to call this API (Next.js frontend).
# Include both local dev and the deployed frontend URL, e.g.:
# CLIENT_ORIGIN=http://localhost:3000,https://ishbor-frontend.vercel.app
CLIENT_ORIGIN=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/ishbor_portal

# JWT (used to authenticate the test-taker on both REST and Socket.io)
JWT_SECRET=replace_this_with_a_long_random_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Assessment engine tuning
TEST_DURATION_MINUTES=30
HEARTBEAT_TIMEOUT_MS=15000
MAX_TAB_SWITCHES=3
MAX_VIOLATIONS=5

# Minutes a candidate must wait after finishing an attempt before starting
# another (anti brute-force / score-oracle guard).
TEST_ATTEMPT_COOLDOWN_MINUTES=10
# If the last scored attempt was below this percentage, the cooldown above is
# multiplied by TEST_LOW_SCORE_COOLDOWN_MULTIPLIER instead of applying as-is.
TEST_LOW_SCORE_THRESHOLD=50
TEST_LOW_SCORE_COOLDOWN_MULTIPLIER=3

# Max accounts allowed to register from the same IP before further signups
# from it are rejected (existing accounts are never touched — only new
# registrations). Keep loose: shared IPs (offices, campuses, NAT) are common.
MAX_ACCOUNTS_PER_IP=2

# Shared secret checked on POST /api/webhooks/questions (X-Webhook-Secret
# header) — used by the automated question-generation script (or Make.com,
# if you use that instead). Leave unset to disable the webhook entirely.
QUESTION_IMPORT_SECRET=

# Below this many total questions for a technology, testController.startTest
# triggers a background Groq refill (services/autoRefillService.ts). Reuses
# GROQ_API_KEY below; leave that unset to disable auto-refill entirely.
AUTO_REFILL_THRESHOLD=15
# Minimum minutes between auto-refill batches for the same technology.
AUTO_REFILL_COOLDOWN_MINUTES=30

# --- scripts/generateQuestions.ts (npm run generate-questions) ---
# Standalone AI question generator. Calls Groq (free tier, no billing setup —
# get a key at console.groq.com), then POSTs the result to this same
# backend's own /api/webhooks/questions (so QUESTION_IMPORT_SECRET above must
# be set too). Run it as its own long-lived process (separate from the API
# server) — it self-schedules via node-cron and never exits.
GROQ_API_KEY=
# Must point at THIS backend's webhook route (local or deployed).
WEBHOOK_URL=http://localhost:5000/api/webhooks/questions
# Cron expression for how often to generate a full batch. Default: daily at 03:00.
GENERATE_CRON=0 3 * * *
# Comma-separated technology ids to generate for. Default: every technology
# in config/catalog.ts (ALL_TECHNOLOGIES).
GENERATE_TECHNOLOGIES=
# Comma-separated difficulties. Default: junior,middle,senior.
GENERATE_DIFFICULTIES=
# Questions requested per Groq call (per technology+difficulty pair). Default: 5.
GENERATE_QUESTIONS_PER_CALL=5
# Set to "true" to run one generation pass immediately and exit — for local
# testing. Omit (or "false") for the normal always-on cron behavior.
RUN_ONCE=false
